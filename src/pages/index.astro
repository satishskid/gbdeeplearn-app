  <script is:inline>
    (() => {
      const chips = Array.from(document.querySelectorAll('.home-insight-filter'));
      if (!chips.length) return;
      const cards = Array.from(document.querySelectorAll('.home-insight-card'));
      const groups = Array.from(document.querySelectorAll('.home-insight-group'));
      const state = { path: 'all' };

      const render = () => {
        cards.forEach((card) => {
          const matches = state.path === 'all' || card.dataset.path === state.path;
          card.style.display = matches ? '' : 'none';
        });

        groups.forEach((group) => {
          const visibleChildren = group.querySelectorAll('.home-insight-card:not([style*="display: none"])').length;
          group.style.display = visibleChildren > 0 ? '' : 'none';
        });

        chips.forEach((chip) => {
          const active = chip.dataset.filterValue === state.path;
          chip.classList.toggle('is-active', active);
        });
      };

      chips.forEach((chip) => {
        chip.addEventListener('click', () => {
          state.path = chip.dataset.filterValue || 'all';
          render();
        });
      });

      render();
    })();
  </script>

