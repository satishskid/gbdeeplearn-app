        <!-- Archive Links -->
        <div class="flex items-center justify-center gap-6 mt-8">
          <a href="/daiy" class="text-slate-500 hover:text-teal-400 transition text-sm font-mono font-bold">
            [DAIY_ARCHIVE →]
