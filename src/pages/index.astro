  </section>

  <script>
    // ─── Pathway Cinema Stage ───────────────────────────────────────────────
    const steps = document.querySelectorAll('.sequence-step');
    const panels = document.querySelectorAll('.cinema-panel');
    const nodes = document.querySelectorAll('.motion-node');
    let currentIndex = 0;
    let autoCycleInterval;

    function updateStage(index) {
      currentIndex = index;
      const target = steps[index].getAttribute('data-target');
      steps.forEach((s, i) => s.classList.toggle('active', i === index));
      panels.forEach(p => p.classList.remove('active'));
      document.getElementById(`panel-${target}`).classList.add('active');
      nodes.forEach(n => n.classList.remove('active'));
      document.getElementById(`node-${target}`).classList.add('active');
    }

    function startAutoCycle() {
      stopAutoCycle();
      autoCycleInterval = setInterval(() => {
        updateStage((currentIndex + 1) % steps.length);
      }, 5000);
    }

    function stopAutoCycle() {
      if (autoCycleInterval) clearInterval(autoCycleInterval);
    }

    steps.forEach((step, index) => {
      step.addEventListener('click', () => {
        updateStage(index);
        startAutoCycle();
      });
    });
    startAutoCycle();

    // ─── DAIY Copy Button ───────────────────────────────────────────────────
    const copyBtn = document.getElementById('daiy-copy-btn');
    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        const prompt = copyBtn.getAttribute('data-prompt') || '';
        try {
          await navigator.clipboard.writeText(prompt);
          const label = document.getElementById('daiy-copy-label');
          if (label) {
            label.textContent = 'Copied!';
            copyBtn.classList.add('daiy-copy-btn--success');
            setTimeout(() => {
              label.textContent = 'Copy Prompt';
              copyBtn.classList.remove('daiy-copy-btn--success');
            }, 2000);
          }
        } catch {
          // Fallback for older browsers
          const el = document.getElementById('daiy-prompt-text');
          if (el) {
            const range = document.createRange();
            range.selectNode(el);
            window.getSelection()?.removeAllRanges();
            window.getSelection()?.addRange(range);
            document.execCommand('copy');
            window.getSelection()?.removeAllRanges();
          }
        }
      });
    }

    // ─── DAIY Like Button ───────────────────────────────────────────────────
    const likeBtn = document.getElementById('daiy-like-btn');
    if (likeBtn) {
      const postId = likeBtn.getAttribute('data-post-id') || '';
      const likedKey = `daiy_liked_${postId}`;
      
      // Restore liked state from localStorage
      if (localStorage.getItem(likedKey)) {
        likeBtn.classList.add('daiy-like-btn--liked');
      }

      likeBtn.addEventListener('click', async () => {
        if (!postId || localStorage.getItem(likedKey)) return;
        
        try {
          const apiOrigin = document.documentElement.getAttribute('data-api-origin') || 'https://deeplearn-worker.satish-9f4.workers.dev';
          const res = await fetch(`${apiOrigin}/api/content/posts/${encodeURIComponent(postId)}/like`, { method: 'POST' });
          const data = await res.json();
          
          localStorage.setItem(likedKey, '1');
          likeBtn.classList.add('daiy-like-btn--liked');
          
          const countEl = document.getElementById('daiy-like-count');
          const labelEl = document.getElementById('daiy-like-label');
          const likes = data?.community_likes ?? 0;
          if (countEl) countEl.textContent = likes > 0 ? likes : '';
          if (labelEl) labelEl.textContent = likes > 0 ? `${likes} doctors liked this` : 'Liked!';
        } catch {
          // Silently fail — don't block the user
        }
      });
    }

    // ─── AI Arena Tabs & Filters ──────────────────────────────────────────
    const arenaTabs = document.querySelectorAll('.arena-tab');
    const arenaPanels = document.querySelectorAll('.arena-category-panel');
    const arenaFilters = document.getElementById('arena-filters');
    const filterBtns = document.querySelectorAll('.arena-filter-btn');

    function updateArenaFilters(category) {
      if (category === 'spaces') {
        arenaFilters?.classList.remove('hidden');
        arenaFilters?.classList.add('flex');
      } else {
        arenaFilters?.classList.remove('flex');
        arenaFilters?.classList.add('hidden');
      }
    }

    arenaTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const category = tab.getAttribute('data-category');
        arenaTabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        arenaPanels.forEach(panel => {
          panel.classList.toggle('active', panel.getAttribute('data-panel') === category);
        });
        updateArenaFilters(category);
      });
    });

    // Space Sorting Logic
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const sortType = btn.getAttribute('data-sort');
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const spacesPanel = document.querySelector('[data-panel="spaces"]');
        const grid = spacesPanel?.querySelector('.daiy-model-links');
        const cards = Array.from(grid?.querySelectorAll('.daiy-model-link-terminal') || []);

        cards.sort((a, b) => {
          if (sortType === 'trending') {
            const aTrend = a.getAttribute('data-trending') === 'true';
            const bTrend = b.getAttribute('data-trending') === 'true';
            return bTrend - aTrend;
          } else {
            const aDate = a.getAttribute('data-date') || '';
            const bDate = b.getAttribute('data-date') || '';
            return bDate.localeCompare(aDate);
          }
        });

        cards.forEach(card => grid?.appendChild(card));
      });
    });

    // Initialize state
    const initialCat = document.querySelector('.arena-tab.active')?.getAttribute('data-category');
    updateArenaFilters(initialCat);
  </script>

</BaseLayout>
