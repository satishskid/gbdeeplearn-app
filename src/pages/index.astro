---
import BaseLayout from '../layouts/BaseLayout.astro';
import CounselorChat from '../components/CounselorChat.jsx';
import WebinarLeadForm from '../components/WebinarLeadForm.jsx';
import HomeEngagementBar from '../components/HomeEngagementBar.jsx';
import AudienceCtaSwitcher from '../components/AudienceCtaSwitcher.jsx';
import { formatDisplayDate, getClinicalFeedPosts, getCourseCatalog, getHuggingFaceModelSpotlights } from '../lib/academyData';
import { fetchPublishedBriefs, getContentTypeMeta } from '../lib/briefs.js';
import { TRACKS } from '../lib/tracks';

const SITE_ORIGIN = 'https://edu.greybrain.ai';
const OG_IMAGE = `${SITE_ORIGIN}/images/seo/greybrain-hero-og.svg`;
const blogPosts = await getClinicalFeedPosts(9);
const modelSpotlights = await getHuggingFaceModelSpotlights(5);
const publishedBriefs = await fetchPublishedBriefs(12).catch(() => []);
const allCourses = await getCourseCatalog();
const featuredCourses = allCourses.slice(0, 6);
const refresherCourse = allCourses.find((course) => course.slug === 'ai-refresher-for-doctors') || null;

const PATH_THEME = {
  productivity: {
    label: 'Practice',
    border: 'border-emerald-300',
    badge: 'bg-emerald-50 text-emerald-800',
    stripe: 'bg-emerald-500'
  },
  research: {
    label: 'Publish',
    border: 'border-sky-300',
    badge: 'bg-sky-50 text-sky-800',
    stripe: 'bg-sky-500'
  },
  entrepreneurship: {
    label: 'Build',
    border: 'border-amber-300',
    badge: 'bg-amber-50 text-amber-800',
    stripe: 'bg-amber-500'
  }
};

const PATH_ILLUSTRATIONS = {
  productivity: '/images/home/practice-path.svg',
  research: '/images/home/research-path.svg',
  entrepreneurship: '/images/home/build-path.svg'
};

function trimSummary(text = '', max = 140) {
  const normalized = String(text || '').replace(/\s+/g, ' ').trim();
  if (!normalized) return '';
  if (normalized.length <= max) return normalized;
  return `${normalized.slice(0, max - 1).trimEnd()}…`;
}

function resolvePathFromText(raw = '', index = 0) {
  const text = String(raw).toLowerCase();
  if (/(research|paper|journal|trial|evidence|study|manuscript|review)/.test(text)) return 'research';
  if (/(startup|venture|founder|business|market|entrepreneur|pilot|mvp)/.test(text)) return 'entrepreneurship';
  if (/(clinical|workflow|documentation|patient|opd|practice|communication)/.test(text)) return 'productivity';
  return ['productivity', 'research', 'entrepreneurship'][index % 3];
}

const publishedFeedCards = publishedBriefs.map((post, index) => {
  const resolvedPathKey = PATH_THEME[post?.path] ? post.path : resolvePathFromText(`${post?.title || ''} ${post?.summary || ''}`, index);
  const typeMeta = getContentTypeMeta(post?.content_type);
  const publishedLabel = formatDisplayDate(post?.date || '') || 'Latest update';
  return {
    ...post,
    summary: trimSummary(post?.summary || '', 156),
    pathKey: resolvedPathKey,
    pathTheme: PATH_THEME[resolvedPathKey],
    sourceLabel: typeMeta.label,
    publishedLabel,
    link: `/briefs/${post.slug}`
  };
});

const fallbackFeedCards = (() => {
  const merged = [];
  let blogIndex = 0;
  let modelIndex = 0;
  while (merged.length < 12 && (blogIndex < blogPosts.length || modelIndex < modelSpotlights.length)) {
    if (blogIndex < blogPosts.length) merged.push(blogPosts[blogIndex++]);
    if (modelIndex < modelSpotlights.length) merged.push(modelSpotlights[modelIndex++]);
  }
  return merged.map((post, index) => {
    const pathHint = String(post?.pathHint || '').toLowerCase();
    const resolvedPathKey = PATH_THEME[pathHint] ? pathHint : resolvePathFromText(`${post?.title || ''} ${post?.summary || ''}`, index);
    const publishedLabel =
      formatDisplayDate(post?.date || '') ||
      (String(post?.source || '').toLowerCase() === 'huggingface' ? 'Trending now' : 'Latest update');
    return {
      ...post,
      summary: trimSummary(post?.summary || '', 156),
      pathKey: resolvedPathKey,
      pathTheme: PATH_THEME[resolvedPathKey],
      sourceLabel: post?.sourceLabel || 'Clinical AI',
      publishedLabel,
      link: post?.link || 'https://greybrain.ai/clinical-ai'
    };
  });
})();

const showcaseFallbacks = {
  workflow: [
    {
      title: 'Paper to family brief',
      summary: 'Turn one study into a plain-language family explanation, key facts, and a patient-safe infographic outline.',
      link: '/briefs/workflow-paper-to-family-brief',
      pathKey: 'research'
    },
    {
      title: 'Clinic note to patient instructions',
      summary: 'Convert clinical notes into patient-facing next steps without losing caution, clarity, or workflow boundaries.',
      link: '/briefs/workflow-clinic-note-to-patient-instructions',
      pathKey: 'productivity'
    },
    {
      title: 'Clinical problem to MVP brief',
      summary: 'Translate a real hospital pain point into a sharper MVP concept, user boundary, and first pilot metric.',
      link: '/briefs/workflow-clinical-problem-to-mvp-brief',
      pathKey: 'entrepreneurship'
    }
  ],
  wiki: [
    {
      title: 'What is RAG for doctors?',
      summary: 'A plain-language explanation of retrieval, context grounding, and why tutor quality changes once sources are attached.',
      link: '/briefs/wiki-what-is-rag-for-doctors',
      pathKey: 'research'
    },
    {
      title: 'What is a model card?',
      summary: 'How to read a model’s strengths, limitations, data lineage, and safety assumptions before trusting it in healthcare.',
      link: '/briefs/wiki-what-is-a-model-card',
      pathKey: 'productivity'
    },
    {
      title: 'What are pilot metrics?',
      summary: 'The minimum signals clinician-founders need before calling an AI workflow useful, safe, or commercially viable.',
      link: '/briefs/wiki-what-are-pilot-metrics',
      pathKey: 'entrepreneurship'
    }
  ],
  model_watch: [
    {
      title: 'Clinical multimodal models',
      summary: 'Which model classes matter when the job includes images, notes, forms, and cross-document clinical reasoning.',
      link: '/briefs/model-watch-clinical-multimodal-models',
      pathKey: 'productivity'
    },
    {
      title: 'Long-context research models',
      summary: 'Models worth testing when the task is protocol comparison, literature synthesis, or reviewer-response support.',
      link: '/briefs/model-watch-long-context-research-models',
      pathKey: 'research'
    },
    {
      title: 'Healthcare operations agents',
      summary: 'A practical watchlist for agent systems that might reduce coordination load without becoming unsafe black boxes.',
      link: '/briefs/model-watch-healthcare-operations-agents',
      pathKey: 'entrepreneurship'
    }
  ]
};

const feedCards = publishedFeedCards.length > 0 ? publishedFeedCards : fallbackFeedCards;
const leadInsight = feedCards[0] || null;
const leadInsightVisual = leadInsight ? PATH_ILLUSTRATIONS[leadInsight.pathKey] || PATH_ILLUSTRATIONS.productivity : PATH_ILLUSTRATIONS.productivity;
const sideInsights = feedCards.slice(1, 4);
const workflowHighlights = (feedCards.filter((post) => post.content_type === 'workflow').slice(0, 3).length > 0
  ? feedCards.filter((post) => post.content_type === 'workflow').slice(0, 3)
  : showcaseFallbacks.workflow.map((item) => ({ ...item, pathTheme: PATH_THEME[item.pathKey] })));
const wikiHighlights = (feedCards.filter((post) => post.content_type === 'wiki').slice(0, 3).length > 0
  ? feedCards.filter((post) => post.content_type === 'wiki').slice(0, 3)
  : showcaseFallbacks.wiki.map((item) => ({ ...item, pathTheme: PATH_THEME[item.pathKey] })));
const modelWatchHighlights = (feedCards.filter((post) => post.content_type === 'model_watch').slice(0, 3).length > 0
  ? feedCards.filter((post) => post.content_type === 'model_watch').slice(0, 3)
  : showcaseFallbacks.model_watch.map((item) => ({ ...item, pathTheme: PATH_THEME[item.pathKey] })));
const intelligenceCanvasCards = [
  {
    label: 'Featured brief',
    title: leadInsight?.title || 'Daily AI signal',
    pathTheme: leadInsight?.pathTheme || PATH_THEME.productivity
  },
  {
    label: 'Workflow',
    title: workflowHighlights[0]?.title || 'Reusable doctor workflow',
    pathTheme: workflowHighlights[0]?.pathTheme || PATH_THEME.productivity
  },
  {
    label: 'Wiki',
    title: wikiHighlights[0]?.title || 'Concept explainer',
    pathTheme: wikiHighlights[0]?.pathTheme || PATH_THEME.research
  },
  {
    label: 'Model watch',
    title: modelWatchHighlights[0]?.title || 'Model note',
    pathTheme: modelWatchHighlights[0]?.pathTheme || PATH_THEME.entrepreneurship
  }
];
const insightPathFilters = [
  { value: 'all', label: 'All Paths' },
  { value: 'productivity', label: 'Practice' },
  { value: 'research', label: 'Publish' },
  { value: 'entrepreneurship', label: 'Build' }
];

const heroTrustPoints = [
  { label: 'Audience', value: 'Doctors, residents, and faculty' },
  { label: 'Format', value: 'Cohorts + AI tutor + mentor review' },
  { label: 'Start', value: 'Interactive refresher before deeper cohorts' },
  { label: 'Recognition', value: 'IIHMRB-linked certificate pathway' }
];

const productLogicStages = [
  {
    label: 'Prompt',
    title: 'Frame the doctor task clearly',
    copy: 'Start with a note, paper, or healthcare problem that already matters.'
  },
  {
    label: 'Context',
    title: 'Attach the right source material',
    copy: 'Guidelines, protocols, syllabus context, and examples change answer quality.'
  },
  {
    label: 'Tutor',
    title: 'Use AI to explain and structure',
    copy: 'GreyBrain helps turn raw material into something usable, not just fluent.'
  },
  {
    label: 'Review',
    title: 'Apply clinical or mentor judgment',
    copy: 'Drafts improve through critique, review, and assignment feedback.'
  },
  {
    label: 'Output',
    title: 'Leave with a real artifact',
    copy: 'Patient instructions, evidence synthesis, slides, pilot briefs, and more.'
  }
];

const pathBoards = [
  {
    key: 'productivity',
    label: 'Practice',
    href: '/tracks/clinical-ai-practitioner',
    title: 'Reduce note, summary, and patient-communication load.',
    copy: 'For doctors who want immediate leverage in OPD, ward, and discharge workflows.',
    bullets: ['Notes -> patient instructions', 'Discharge -> family update', 'Guideline -> clinic checklist']
  },
  {
    key: 'research',
    label: 'Publish',
    href: '/tracks/ai-research-accelerator',
    title: 'Accelerate literature, evidence, and manuscript execution.',
    copy: 'For residents and faculty who want stronger research execution without losing rigor.',
    bullets: ['Paper -> synthesis', 'Reviewer comments -> response matrix', 'Protocol -> slide deck']
  },
  {
    key: 'entrepreneurship',
    label: 'Build',
    href: '/tracks/doctor-ai-entrepreneurship',
    title: 'Move from healthcare insight to pilot and venture brief.',
    copy: 'For clinicians validating ideas, clarifying users, and making concepts testable.',
    bullets: ['Pain point -> MVP brief', 'Workflow -> pilot KPI sheet', 'Capstone -> founder story']
  }
];
const featuredPathBoard = pathBoards[0];
const secondaryPathBoards = pathBoards.slice(1);

const academySignals = [
  {
    label: 'Starter flow',
    value: 'Refresher before cohort',
    copy: 'Understand the mechanics first, then choose the deeper path.',
    chips: ['20-30 min', 'Interactive']
  },
  {
    label: 'Support layer',
    value: 'AI tutor + mentor review',
    copy: 'Use AI for drafts, then sharpen work with review and critique.',
    chips: ['Drafting', 'Critique']
  },
  {
    label: 'Outcome model',
    value: 'Practice / Publish / Build',
    copy: 'One foundation, three visible routes for doctor outcomes.',
    chips: ['Clinical', 'Research', 'Venture']
  }
];

const coursePathBySlug = new Map();
for (const track of TRACKS) {
  const pathKey =
    track.slug === 'ai-research-accelerator'
      ? 'research'
      : track.slug === 'doctor-ai-entrepreneurship'
        ? 'entrepreneurship'
        : 'productivity';
  for (const slug of track.courseSlugs) {
    if (!coursePathBySlug.has(slug)) coursePathBySlug.set(slug, pathKey);
  }
}

const courseCards = featuredCourses.map((course, index) => {
  const inferredPath = course.trackHint || coursePathBySlug.get(course.slug) || resolvePathFromText(`${course.name} ${course.shortDescription || ''}`, index);
  return {
    ...course,
    shortDescription: trimSummary(course.shortDescription || '', 134),
    pathKey: inferredPath,
    pathTheme: PATH_THEME[inferredPath],
    stateLabel: course.accessModel === 'registration' ? 'Starter' : 'Cohort open',
    deliveryLabel: course.accessModel === 'registration' ? 'Unlock after registration' : 'Cohort + AI tutor'
  };
});

const courseBySlug = new Map(allCourses.map((course) => [course.slug, course]));

const starterCourseCard = refresherCourse
  ? {
      ...refresherCourse,
      shortDescription: trimSummary(refresherCourse.shortDescription || '', 164),
      pathKey: 'productivity',
      pathTheme: PATH_THEME.productivity,
      stateLabel: 'Starter',
      deliveryLabel: 'Unlock after registration'
    }
  : null;

const cohortOfferBlueprints = [
  { pathKey: 'productivity', slug: 'gen-ai-doctors-express' },
  { pathKey: 'research', slug: 'ai-for-research-papers' },
  { pathKey: 'entrepreneurship', slug: 'super-agents' }
];

const cohortOfferCards = cohortOfferBlueprints
  .map(({ pathKey, slug }) => {
    const course = courseBySlug.get(slug);
    if (!course) return null;
    return {
      ...course,
      shortDescription: trimSummary(course.shortDescription || '', 134),
      pathKey,
      pathTheme: PATH_THEME[pathKey],
      stateLabel: 'Cohort open',
      deliveryLabel: 'Cohort + AI tutor'
    };
  })
  .filter(Boolean);

const featuredCohortOffer = cohortOfferCards[0] || null;
const secondaryCohortOffers = cohortOfferCards.slice(1, 3);

const organizationStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: 'GreyBrain Academy',
  url: `${SITE_ORIGIN}/`,
  sameAs: ['https://greybrain.ai/academy', 'https://greybrain.ai/clinical-ai'],
  description:
    'No-code AI learning for doctors across clinical productivity, research acceleration, and healthcare entrepreneurship.',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'GreyBrain Healthcare AI Courses',
    itemListElement: allCourses.map((course) => ({
      '@type': 'Course',
      name: course.name,
      url: `${SITE_ORIGIN}/courses/${course.slug}`,
      provider: {
        '@type': 'Organization',
        name: 'GreyBrain Academy'
      }
    }))
  }
};

const websiteStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'GreyBrain Academy',
  url: `${SITE_ORIGIN}/`,
  description:
    'AI courses for doctors across clinical productivity, research acceleration, and healthcare entrepreneurship.',
  inLanguage: 'en'
};

const credentialStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOccupationalCredential',
  name: 'GreyBrain Academy Program Certification (IIHMRB)',
  recognizedBy: {
    '@type': 'Organization',
    name: 'IIHMR Bangalore (IIHMRB)'
  },
  url: `${SITE_ORIGIN}/certifications/iihmrb-generative-ai-for-doctors-certificate.pdf`,
  description:
    'GreyBrain Academy cohorts include certification recognition from IIHMR Bangalore for eligible program completion.'
};
---

<BaseLayout
  title="GreyBrain Academy | AI courses for doctors who want to practice, publish, and build"
  description="GreyBrain Academy helps doctors use AI for clinical productivity, research acceleration, and healthcare entrepreneurship through cohort-based learning and AI tutor support."
  canonical={`${SITE_ORIGIN}/`}
  ogImage={OG_IMAGE}
  ogImageAlt="GreyBrain Academy - AI-enabled learning for doctors"
>
  <script type="application/ld+json" set:html={JSON.stringify(organizationStructuredData)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteStructuredData)} />
  <script type="application/ld+json" set:html={JSON.stringify(credentialStructuredData)} />

  <div class="mockup-hero-container">
    <section class="mockup-hero">
      <div class="mockup-hero-content">
        <h1 class="mockup-title">The AI Academy for Doctors</h1>
        <h2 class="mockup-subtitle">Practice, Publish, and Build</h2>
        
        <p class="mockup-description">
          Unlock Your Medical Career with Artificial Intelligence<br/>
          <span class="mockup-description-sub">Master AI implementation, accelerate medical research, and advance your<br/>professional journey with world-class faculty.</span>
        </p>
        <div class="mt-8 flex justify-center">
          <AudienceCtaSwitcher client:load enrollTargetId="enroll" />
        </div>
      </div>
    </section>

    <div class="mockup-cards-wrapper">
      <div class="mockup-cards-grid">
        <!-- Practice Card -->
        <article class="mockup-card">
          <div class="mockup-card-icon">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <p class="mockup-card-kicker">(Practice)</p>
          <h3 class="mockup-card-title">CLINICAL AI<br/>MASTERCLASS</h3>
          <p class="mockup-card-copy">Level 1: AI Tools for<br/>Diagnosis & Workflow</p>
          <div class="mockup-card-action">
            <a href="/tracks/clinical-ai-practitioner" class="mockup-btn">Enroll Now</a>
          </div>
        </article>

        <!-- Publish Card -->
        <article class="mockup-card">
          <div class="mockup-card-icon">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <p class="mockup-card-kicker">(Publish)</p>
          <h3 class="mockup-card-title">RESEARCH &<br/>PUBLICATION<br/>ACCELERATOR</h3>
          <p class="mockup-card-copy">Write & Publish AI-driven<br/>Research Papers</p>
          <div class="mockup-card-action">
            <a href="/tracks/ai-research-accelerator" class="mockup-btn">Explore Path</a>
          </div>
        </article>

        <!-- Build Card -->
        <article class="mockup-card">
          <div class="mockup-card-icon">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" />
            </svg>
          </div>
          <p class="mockup-card-kicker">(Build)</p>
          <h3 class="mockup-card-title">AI INNOVATION &<br/>LEADERSHIP</h3>
          <p class="mockup-card-copy">Develop & Deploy Your<br/>Own AI Solutions</p>
          <div class="mockup-card-action">
            <a href="/tracks/doctor-ai-entrepreneurship" class="mockup-btn">Learn More</a>
          </div>
        </article>
      </div>

      <div class="mockup-trust-strip">
        <a href="/certifications/iihmrb-generative-ai-for-formations-certificate.pdf" target="_blank" rel="noreferrer" class="mockup-trust-item inline-flex items-center gap-2">
          <svg class="w-8 h-8 text-slate-700" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          <div class="text-left leading-tight"><strong class="block text-slate-900 border-b border-slate-300 pb-0.5 mb-0.5">IIHMRB</strong> Recognized</div>
        </a>
        <div class="mockup-trust-item inline-flex items-center gap-2">
           <svg class="w-8 h-8 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
           <div class="text-left leading-tight"><strong class="block text-slate-900">CME</strong> Accredited Provider</div>
        </div>
        <div class="mockup-trust-item inline-flex items-center gap-2">
          <svg class="w-8 h-8 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>
          <div class="text-left leading-tight"><strong class="block text-slate-900">Peer Reviewed</strong> Courses</div>
        </div>
      </div>
    </div>
  </div>

  <section class="public-section reveal-up reveal-delay-1 mb-16 mt-12 bg-white">
    <div class="academy-logic-grid">
      <article class="academy-logic-intro">
        <p class="public-section-kicker">How GreyBrain works</p>
        <h2 class="public-section-title">GreyBrain lowers the barrier before it raises the ambition.</h2>
        <p class="public-section-copy">
          Doctors do not need more vague AI noise. They need one clear system that explains how AI becomes reliable work in practice,
          research, and venture building.
        </p>
        <div class="academy-logic-points">
          <span>Doctor language</span>
          <span>Real tasks</span>
          <span>AI tutor</span>
          <span>Mentor review</span>
        </div>
      </article>

      <div class="academy-logic-map">
        <div class="academy-logic-rail" aria-hidden="true"></div>
        {productLogicStages.map((stage, index) => (
          <article class={`academy-logic-step academy-logic-step--${index === 2 ? 'core' : 'edge'}`}>
            <div class="academy-logic-step-index">{String(index + 1).padStart(2, '0')}</div>
            <div class="academy-logic-step-body">
              <p class="academy-manifesto-label">{stage.label}</p>
              <h3>{stage.title}</h3>
              <p>{stage.copy}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="public-section reveal-up reveal-delay-2 mb-16 bg-slate-50 border-y border-slate-100 py-12">
    <div class="public-section-head public-section-head--action">
      <div>
        <p class="public-section-kicker">Three outcome paths</p>
        <h2 class="public-section-title">One foundation. Three visible doctor futures.</h2>
      </div>
      <div class="academy-path-caption">Choose the first outcome you want AI to improve.</div>
    </div>
    <div class="academy-path-stage mt-6">
