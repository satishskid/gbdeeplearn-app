---
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatDisplayDate, getCourseCatalog, getHuggingFaceModelSpotlights, getHuggingFaceSpacesSpotlights } from '../lib/academyData';
import { fetchPublishedBriefs, fetchLatestByType, fetchHomepageConfig, fetchSpotlightedPosts } from '../lib/briefs.js';

const modelSpotlights = await getHuggingFaceModelSpotlights(5);
const spacesSpotlights = await getHuggingFaceSpacesSpotlights(5);
const publishedBriefs = await fetchPublishedBriefs(6).catch(() => []);
const allCourses = await getCourseCatalog();
const refresherCourse = allCourses.find((course) => course.slug === 'ai-refresher-for-doctors') || null;

// Fetch latest daily-generated content for each section
const latestModelSpotlight = await fetchLatestByType('model_spotlight').catch(() => null);
const latestDaiy = await fetchLatestByType('daiy_prompt').catch(() => null);
const latestHealthNews = await fetchPublishedBriefs(3).catch(() => []);

// Phase 8: Dynamic homepage config (ticker text, spotlight flags)
const homepageConfig = await fetchHomepageConfig().catch(() => ({}));
const spotlightedBriefs = await fetchSpotlightedPosts(publishedBriefs).catch(() => []);
const spotlightedIds = new Set(spotlightedBriefs.map((p) => p.id));
const tickerText = homepageConfig?.ticker_text?.trim() ||
  '🧠 Merlin (Stanford, Nature 2026) — native 3D volumetric VLM for CT/MRI · 🏆 Open Medical LLM Leaderboard updated · 🤖 Google MedGemma expansion · 📋 SAHI India Strategy rollout · ⚡ AbraHealth FDA clearance for autonomous triage · ✨ GreyBrain Cohort 3 applications open — apply now';

// Featured HuggingFace model (first from trending list)
const featuredModel = modelSpotlights[0] || null;

// DAIY: parse prompt data from DB post or use fallback
const daiyPrompt = latestDaiy?.prompt_text || `I am a physician. Act as an empathetic Medical Communication Agent. Take the attached clinical note and transform it into:
1) An ‘After Visit Summary’ written at a 5th-grade reading level (warm tone).
2) A ‘Why This Matters’ section explaining the diagnosis without jargon.
3) A visual ‘Home Care Checklist’ using emojis for easy scanning.`;

const daiyKeyword = latestDaiy?.prompt_keyword || 'Patient Communication';
const daiyPreview = latestDaiy?.prompt_output_preview || 'You\'ll receive a structured, doctor-vetted breakdown that transforms dense clinical language into clear, actionable takeaways — ready for your next consultation or social post.';
const daiyLikes = latestDaiy?.community_likes || 0;
const daiyPostId = latestDaiy?.id || '';

// Comprehensive Classified Model & Space Arena (Exhaustive 2026 Directory)
const DAIY_ARENA = {
  categories: [
    { id: 'logic', label: 'Clinical Logic (CoT)' },
    { id: 'imaging', label: 'Imaging & Multimodal' },
    { id: 'agents', label: 'Clinical Agents & Scribes' },
    { id: 'research', label: 'Bio / Pharma / Labs' },
    { id: 'spaces', label: 'Interactive HF Spaces' }
  ],
  models: {
    logic: [
      { name: 'DeepSeek-R1', url: 'https://chat.deepseek.com', desc: '671B MoE. State-of-the-art medical CoT.', trending: true, date: '2025-01' },
      { name: 'Qwen 3.5-Max', url: 'https://chat.qwen.ai', desc: 'Doctoral-level scientific QA specialist.', trending: true, date: '2026-02' },
      { name: 'OpenAI o1', url: 'https://chatgpt.com', desc: 'Reasoning-heavy medical diagnostics.', trending: false, date: '2024-11' },
      { name: 'Claude 3.5 Sonnet', url: 'https://claude.ai', desc: 'Precision reasoning & medical ethics.', trending: false, date: '2024-10' },
      { name: 'Kimi K2.5', url: 'https://kimi.moonshot.cn', desc: 'Ultra-long context clinical reasoning.', trending: true, date: '2026-01' },
      { name: 'GLM-5', url: 'https://chatglm.cn', desc: 'Advanced multi-step clinical deduction.', trending: true, date: '2026-03' },
      { name: 'Starling-LM-7B', url: 'https://huggingface.co/berkeley-nest/starling-lm-7b-alpha', desc: 'Top-tier open medical QA weights.', trending: false, date: '2024-05' },
      { name: 'Hermes-3-Pro', url: 'https://huggingface.co/NousResearch/Hermes-3-Llama-3.1-405B', desc: 'Complex medical instruction following.', trending: true, date: '2025-08' },
      { name: 'Meditron-V3', url: 'https://huggingface.co/medical-ai/meditron-v3-70b', desc: 'Llama-3 fine-tuned on PubMed v2.', trending: true, date: '2025-11' },
      { name: 'Instruction-Med', url: 'https://huggingface.co/medicalai/instruction-med-13b', desc: 'Clinical guidelines alignment.', trending: false, date: '2024-12' },
      { name: 'BioMistral-v2', url: 'https://huggingface.co/BioMistral/BioMistral-7B-v2', desc: 'Specialized biomedical MoE.', trending: false, date: '2025-03' }
    ],
    imaging: [
      { name: 'Gemini 2.0 Pro', url: 'https://gemini.google.com', desc: 'Native multimodal EHR + Radiology.', trending: true, date: '2025-12' },
      { name: 'MedImageInsight', url: 'https://azure.microsoft.com', desc: 'Microsoft foundation for 14 modalities.', trending: true, date: '2025-06' },
      { name: 'MedGemma-2', url: 'https://huggingface.co/google/medgemma-2-27b', desc: 'Advanced open weights for imaging.', trending: true, date: '2026-01' },
      { name: 'Merlin (3D VLM)', url: 'https://huggingface.co/stanford/merlin-3d-vlm', desc: 'Native 3D clinical vision for volumetric CT/MRI.', trending: true, date: '2026-03', spotlight: true },
      { name: 'Rad-Dino-V2', url: 'https://huggingface.co/microsoft/Rad-DINO-V2', desc: 'Global radiology foundation leader.', trending: true, date: '2025-10' },
      { name: 'GLM-Vision-5', url: 'https://github.com/THUDM/GLM-5', desc: '3D spatial reasoning for CT/MRI scans.', trending: true, date: '2026-03' },
      { name: 'BioViL-L', url: 'https://huggingface.co/microsoft/BioViL-L', desc: 'Vision-language foundation for CXR.', trending: false, date: '2024-09' },
      { name: 'LLaVA-Med-v2', url: 'https://huggingface.co/microsoft/llava-med-v2', desc: 'Visual clinical chat & instruction.', trending: false, date: '2025-02' },
      { name: 'PathAI-Dino', url: 'https://www.pathai.com', desc: 'Digital pathology feature extractor.', trending: false, date: '2024-05' },
      { name: 'Aidoc-Core', url: 'https://www.aidoc.com', desc: 'Real-time radiology prioritization.', trending: false, date: '2024-08' },
      { name: 'MedImageParse-V2', url: 'https://github.com/microsoft/MedImageParse', desc: 'Volumetric medical image segmentation.', trending: true, date: '2025-11' }
    ],
    agents: [
      { name: 'Polaris 4.0', url: 'https://www.hippocraticai.com', desc: 'Next-gen patient-facing nursing suite.', trending: true, date: '2026-03' },
      { name: 'Glass Health', url: 'https://glass.health', desc: 'Precision diagnostic & treatment agent.', trending: false, date: '2024-05' },
      { name: 'Amboss LiSA', url: 'https://www.amboss.com', desc: 'Evidence-based clinical decision suite.', trending: false, date: '2024-06' },
      { name: 'JSL Clinical Assistant', url: 'https://www.johnsnowlabs.com', desc: 'Verified clinical notes & extraction.', trending: true, date: '2025-09' },
      { name: 'Abridge-Med', url: 'https://www.abridge.com', desc: 'Real-time doctor-patient scribe.', trending: true, date: '2025-07' },
      { name: 'Suki-AI', url: 'https://www.suki.ai', desc: 'Voice-enabled AI assistant for EHR.', trending: false, date: '2024-03' },
      { name: 'Augmedix', url: 'https://augmedix.com', desc: 'Ambient automation for clinical visits.', trending: false, date: '2024-11' },
      { name: 'Clinical-Copilot', url: 'https://github.com/microsoft/clinical-copilot', desc: 'EHR-integrated decision support.', trending: true, date: '2025-12' },
      { name: 'Health-Scribe', url: 'https://aws.amazon.com/healthscribe', desc: 'AWS clinical note generator.', trending: false, date: '2024-01' },
      { name: 'MedGPT-Scribe', url: 'https://huggingface.co/med-ai/medgpt-scribe', desc: 'Open-weights clinical transcription.', trending: false, date: '2025-04' }
    ],
    research: [
      { name: 'AlphaFold 3', url: 'https://alphafoldserver.com', desc: 'Google DeepMind protein agent.', trending: true, date: '2024-05' },
      { name: 'ESM-3 (Evolutionary)', url: 'https://www.evolutionaryscale.ai', desc: 'Next-gen biological foundation.', trending: true, date: '2024-07' },
      { name: 'TamGen-V2', url: 'https://github.com/microsoft/TamGen', desc: 'Microsoft drug target design suite.', trending: true, date: '2026-01' },
      { name: 'BioNeMo (NVIDIA)', url: 'https://www.nvidia.com/bionemo', desc: 'High-compute biology simulation.', trending: true, date: '2025-08' },
      { name: 'BioGPT-Max', url: 'https://huggingface.co/microsoft/biogpt-large', desc: 'Microsoft generative biology.', trending: false, date: '2024-03' },
      { name: 'Protein-LM', url: 'https://huggingface.co/facebook/esm2_t33_650M_UR50D', desc: 'Meta protein language expert.', trending: false, date: '2023-09' },
      { name: 'Stanford Med-RAG', url: 'https://huggingface.co/med-ai', desc: 'Research-grounded medical RAG.', trending: true, date: '2025-11' },
      { name: 'TamGen-SRE', url: 'https://github.com/microsoft/TamGen', desc: 'Tampering-resistant drug design.', trending: false, date: '2025-12' },
      { name: 'OpenBioML', url: 'https://openbioml.org', desc: 'Decentralized biological research.', trending: true, date: '2026-02' }
    ],
    spaces: [
      { name: 'Open Med-LLM Leaderboard', url: 'https://huggingface.co/spaces/open-medical-llm/leaderboard', desc: 'Real-time ranking of medical AI.', trending: true, date: '2026-03' },
      { name: 'Radiology Explainer', url: 'https://huggingface.co/spaces/google/rad_explain', desc: 'AI-led imaging interpretations.', trending: true, date: '2024-11' },
      { name: 'EHR Navigator Agent', url: 'https://huggingface.co/spaces/google/ehr-navigator-agent-with-medgemma', desc: 'Complex record search agent.', trending: true, date: '2024-12' },
      { name: 'Path Foundation Demo', url: 'https://huggingface.co/spaces/google/path-foundation-demo', desc: 'Digital pathology classification.', trending: true, date: '2024-10' },
      { name: 'Symptom Analyzer Pro', url: 'https://huggingface.co/spaces/gnumanth/MedGemma-Symptoms', desc: 'Interactive clinical reasoning.', trending: true, date: '2026-01' },
      { name: 'Med-Flamingo-V2', url: 'https://huggingface.co/spaces/med-ai/med-flamingo-demo', desc: 'Medical Visual Chat (VQA).', trending: false, date: '2025-05' },
      { name: 'Med-PaLM Benchmark', url: 'https://huggingface.co/spaces/medical-ai/med-benchmark', desc: 'Clinical evaluation arena.', trending: true, date: '2025-01' },
      { name: 'BioBERT-NER-HF', url: 'https://huggingface.co/spaces/biomedical/biobert-ner', desc: 'PubMed entity extractor.', trending: false, date: '2023-04' },
      { name: 'HealthSearch-Live', url: 'https://huggingface.co/spaces/google/healthsearch', desc: 'Verified clinical info search.', trending: true, date: '2026-02' },
      { name: 'Med-PaLM 2 Playground', url: 'https://huggingface.co/spaces/medical-ai/Med-PaLM', desc: 'Google clinical trial arena.', trending: true, date: '2025-09' },
      { name: 'Brain Seg Demo', url: 'https://huggingface.co/spaces/akhaliq/Brain_Tumor_Segmentation', desc: 'Interactive MRI segmentation.', trending: false, date: '2024-03' },
      { name: 'Clinical-Note-Assist', url: 'https://huggingface.co/spaces/clinical-ai/note-assistant', desc: 'Automated note structuring demo.', trending: true, date: '2026-02' },
      { name: 'Med-Summarizer-HF', url: 'https://huggingface.co/spaces/biomedical/summarizer', desc: 'Clinical literature summarizer.', trending: true, date: '2025-10' },
      { name: 'Drug-Discovery-LM', url: 'https://huggingface.co/spaces/chem-ai/drug-discovery', desc: 'Molecular design interactive.', trending: true, date: '2026-03' }
    ]
  }
};

// Selection logic for daily prompt (Optional: metadata-driven in future)
const arenaRecommended = latestDaiy?.model_tag || 'logic';

const SITE_ORIGIN = 'https://med.greybrain.ai';
const daiyShareText = encodeURIComponent(`I just tried today's #DAIY prompt from @GreyBrainAcademy 🧠\n\nPrompt topic: "${daiyKeyword}"\n\nTry it yourself: ${SITE_ORIGIN} #AIForDoctors #ClinicalAI`);
const daiyXUrl = `https://twitter.com/intent/tweet?text=${daiyShareText}`;
const daiyLinkedInUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(SITE_ORIGIN)}`;
---

<BaseLayout
  title="DeepLearn AI | The Applied AI Incubator for Doctors"
  description="Move from AI Hype to Clinical Evidence. The first applied AI incubator designed for doctors — with daily AI model spotlights, curated prompts (DAIY), and AI healthcare news."
  canonical={SITE_ORIGIN}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "GreyBrain Academy",
      "url": SITE_ORIGIN,
      "description": "The first applied AI incubator for doctors. Daily AI model spotlights, DAIY prompts, and AI healthcare news.",
      "potentialAction": { "@type": "SearchAction", "target": `${SITE_ORIGIN}/briefs?q={search_term_string}`, "query-input": "required name=search_term_string" }
    })} />
  </Fragment>
  <!-- 1. THE HOOK (Hero) -->
  <section class="section-container">
    <div class="max-w-4xl">
      <p class="inline-flex rounded-full bg-teal-50 px-3 py-1 text-xs font-bold uppercase tracking-[0.14em] text-teal-700 mb-6">
        Applied AI Academy for Healthcare
      </p>
      <h1 class="text-5xl md:text-7xl leading-[1.1] mb-8">
        Move from AI Hype to <span class="text-teal-700">Clinical Evidence.</span>
      </h1>
      <p class="text-xl text-slate-600 leading-relaxed mb-10 max-w-2xl">
        The first applied AI incubator designed for doctors. Launch ventures, publish rigorous research, and automate your practice through 8-week mentored cohorts.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/courses/ai-refresher-for-doctors" class="nav-btn !px-8 !py-4 !text-lg">Start AI Refresher</a>
        <a href="#paths" class="inline-flex items-center gap-2 text-lg font-bold text-slate-800 hover:text-teal-700 transition">
          View Learning Paths 
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- DYNAMIC NEWS TICKER (admin-controlled via Homepage Control) -->
  <div class="news-ticker-bar" aria-label="Clinical AI news ticker">
    <div class="news-ticker-inner">
      <span class="news-ticker-label">📡 LIVE</span>
      <div class="news-ticker-scroll-outer">
        <div class="news-ticker-scroll">
          <span>{tickerText}</span>
          <span aria-hidden="true">&nbsp;&nbsp;·&nbsp;&nbsp;{tickerText}</span>
        </div>
      </div>
    </div>
  </div>

  <!-- 2. THE INFRASTRUCTURE (How) -->
  <section class="bg-slate-50 border-y border-slate-100 py-24">
    <div class="section-container">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl mb-4">A Grounded Learning Loop</h2>
        <p class="text-slate-600 text-lg max-w-2xl mx-auto">
          We don't just teach prompt engineering. We provide the operational infrastructure for clinicians to build and lead.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- AI Tutor -->
        <article class="bg-white p-8 rounded-3xl border border-slate-200 shadow-sm hover:shadow-md transition">
          <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 9h8"/><path d="M8 13h6"/></svg>
          </div>
          <h3 class="text-xl mb-3">Syllabus-Grounded AI Tutor</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Study clinical concepts with an AI agent constrained to your specific course syllabus and medical protocols.
          </p>
        </article>

        <!-- Lab Studio -->
        <article class="bg-white p-8 rounded-3xl border border-slate-200 shadow-sm hover:shadow-md transition">
          <div class="w-12 h-12 bg-teal-50 text-teal-600 rounded-xl flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12V2h20v10"/><path d="m9 18 3 3 3-3"/><path d="M12 22V13"/><path d="M11 13H5a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h4"/><path d="M13 13h6a2 2 0 0 1 2 2v4a2 2 0 0 1-2 2h-4"/></svg>
          </div>
          <h3 class="text-xl mb-3">The Experiment Lab Studio</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Execute no-code experiments using open-source HuggingFace models for literature synthesis and predictive research.
          </p>
        </article>

        <!-- Human Review -->
        <article class="bg-white p-8 rounded-3xl border border-slate-200 shadow-sm hover:shadow-md transition">
          <div class="w-12 h-12 bg-amber-50 text-amber-600 rounded-xl flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="text-xl mb-3">Human-in-the-Loop Review</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Every experimental artifact and project is reviewed by clinical coordinators to ensure methodological rigor.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- 3. THE CORE TRACKS (Pathway Cinema Stage) -->
  <section id="paths" class="py-24">
    <div class="section-container">
      <div class="pathway-cinema-shell">
        <div class="pathway-cinema-stage">
          
          <!-- Content Evolution -->
          <div class="cinema-evolution">
            
            <!-- Path 01: Practice -->
            <div id="panel-practice" class="cinema-panel active">
              <span class="cinema-kicker">Path 01: Practice</span>
              <h2 class="cinema-title">Automate your <span class="text-teal-400">documentation</span>, not your judgment.</h2>
              <p class="cinema-desc">Build personalized AI documentation templates, automate follow-up communication, and implement safe patient-facing AI boundaries.</p>
              <div class="flex gap-4">
                <a href="/tracks/clinical-ai-practitioner" class="nav-btn !px-8 !py-3 !bg-teal-500 hover:!bg-teal-400">View Prototype SOPs</a>
                <a href="/courses/gen-ai-doctors-express" class="inline-flex items-center text-white/60 hover:text-white transition gap-2 font-bold text-sm">Express Track &rarr;</a>
              </div>
            </div>

            <!-- Path 02: Publish -->
            <div id="panel-publish" class="cinema-panel">
              <span class="cinema-kicker">Path 02: Publish</span>
              <h2 class="cinema-title">Accelerate <span class="text-blue-400">evidence synthesis</span> with AI rigour.</h2>
              <p class="cinema-desc">Execute in-silico experiments using advanced open-source models. Move from hypothesis to publication-ready manuscript outline.</p>
              <div class="flex gap-4">
                <a href="/tracks/ai-research-accelerator" class="nav-btn !px-8 !py-3 !bg-blue-600 hover:!bg-blue-500">Enter Research Lab</a>
                <a href="/app/research-lab" class="inline-flex items-center text-white/60 hover:text-white transition gap-2 font-bold text-sm">Open Laboratory &rarr;</a>
              </div>
            </div>

            <!-- Path 03: Build -->
            <div id="panel-build" class="cinema-panel">
              <span class="cinema-kicker">Path 03: Build</span>
              <h2 class="cinema-title">From clinical friction to <span class="text-amber-400">pilot-ready MVP.</span></h2>
              <p class="cinema-desc">Designed for doctor-founders. Solve your own clinical friction by building AI-enabled services and validated product briefs.</p>
              <div class="flex gap-4">
                <a href="/tracks/doctor-ai-entrepreneurship" class="nav-btn !px-8 !py-3 !bg-amber-600 hover:!bg-amber-500">Build Your Venture</a>
                <span class="inline-flex items-center text-white/40 gap-2 font-bold text-sm">Incubator Mode</span>
              </div>
            </div>

            <!-- Sequence Tracker -->
            <div class="sequence-tracker">
              <div class="sequence-step active" data-target="practice">
                <div class="step-bar"></div>
                <span class="step-label">Practice</span>
              </div>
              <div class="sequence-step" data-target="publish">
                <div class="step-bar"></div>
                <span class="step-label">Publish</span>
              </div>
              <div class="sequence-step" data-target="build">
                <div class="step-bar"></div>
                <span class="step-label">Build</span>
              </div>
            </div>
          </div>

          <!-- Motion Node Visuals -->
          <div class="cinema-visual-stage">
            
            <!-- Practice Node -->
            <div id="node-practice" class="motion-node active">
              <div class="node-pulse"></div>
              <div class="relative z-10 w-64 h-80 bg-slate-800/50 rounded-3xl border border-white/10 backdrop-blur-xl p-6 flex flex-col justify-center items-center text-center">
                 <div class="w-20 h-20 bg-teal-500/20 rounded-2xl flex items-center justify-center mb-6 text-teal-400">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="m10 9-2 2 2 2"/></svg>
                 </div>
                 <p class="text-xs font-mono text-teal-400/60 mb-2">Automation Scanner</p>
                 <div class="h-1 w-32 bg-teal-500/20 rounded-full overflow-hidden">
                    <div class="h-full bg-teal-400 animate-[progressFill_2s_infinite]"></div>
                 </div>
              </div>
            </div>

            <!-- Publish Node -->
            <div id="node-publish" class="motion-node">
              <div class="node-grid-scan"></div>
              <div class="relative z-10 w-72 h-72 bg-blue-900/40 rounded-full border border-blue-400/20 backdrop-blur-xl flex flex-col justify-center items-center text-center">
                 <div class="w-16 h-16 bg-blue-400/20 rounded-full flex items-center justify-center mb-4 text-blue-300">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22.5V12"/></svg>
                 </div>
                 <p class="text-[10px] font-bold text-blue-300 uppercase tracking-widest">In-Silico Investigator</p>
                 <p class="text-[8px] text-blue-300/60 mt-2 px-10">Synthesizing Evidence via HF Models...</p>
              </div>
