---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCourseCatalog } from '../../lib/academyData';
import { TRACKS } from '../../lib/tracks';

const SITE_ORIGIN = 'https://med.greybrain.ai';
const courses = await getCourseCatalog();

const pathBySlug = new Map();
for (const track of TRACKS) {
  const pathKey =
    track.slug === 'ai-research-accelerator'
      ? 'research'
      : track.slug === 'doctor-ai-entrepreneurship'
        ? 'entrepreneurship'
        : 'productivity';
  for (const slug of track.courseSlugs) {
    if (!pathBySlug.has(slug)) pathBySlug.set(slug, pathKey);
  }
}

const PATH_META = {
  productivity: {
    label: 'Practice',
    badge: 'bg-emerald-50 text-emerald-800',
    border: 'border-emerald-300'
  },
  research: {
    label: 'Publish',
    badge: 'bg-sky-50 text-sky-800',
    border: 'border-sky-300'
  },
  entrepreneurship: {
    label: 'Build',
    badge: 'bg-amber-50 text-amber-800',
    border: 'border-amber-300'
  }
};

const enrichedCourses = courses.map((course, index) => {
  const fallbackKey = ['productivity', 'research', 'entrepreneurship'][index % 3];
  const pathKey = course.trackHint || pathBySlug.get(course.slug) || fallbackKey;
  return {
    ...course,
    pathKey,
    pathTheme: PATH_META[pathKey]
  };
});
---

<BaseLayout
  title="GreyBrain Courses | AI programs for doctors"
  description="Explore GreyBrain healthcare AI courses for clinicians, researchers, and doctor-founders."
  canonical={`${SITE_ORIGIN}/courses`}
>
  <section class="public-hero public-hero--compact reveal-up mb-8">
    <div class="public-hero-copy">
      <div class="public-hero-topline">
        <span class="public-kicker">Course catalog</span>
      </div>
      <h1 class="public-hero-title public-hero-title--catalog">Courses for doctors who want to use AI in practice, research, and venture building.</h1>
      <p class="public-hero-body">
        Every course page should tell a doctor what changes after completion: what they can do faster, what they understand better,
        and what artifact or workflow they can actually produce.
      </p>
    </div>
    <aside class="public-hero-panel public-hero-panel--compact">
      <div class="public-panel-stack">
        <article class="public-panel-card public-panel-card--soft">
          <p class="public-panel-label">Learning model</p>
          <p class="public-panel-value">Cohorts, AI tutor support, assignments, and mentor-reviewed outputs</p>
        </article>
        <article class="public-panel-card public-panel-card--soft">
          <p class="public-panel-label">Best entry</p>
          <p class="public-panel-value">Start with the AI Refresher, then move into the right full pathway</p>
        </article>
      </div>
    </aside>
  </section>

  <section class="public-section reveal-up reveal-delay-1">
    <div class="public-section-head public-section-head--action">
      <div>
        <p class="public-section-kicker">All programs</p>
        <h2 class="public-section-title">A cleaner catalog with clearer outcomes.</h2>
        <p class="public-section-copy">The catalog is now structured to read like an academy, not a form directory.</p>
      </div>
      <a href="/tracks" class="public-inline-action">Compare paths</a>
    </div>

    <div class="public-course-grid public-course-grid--catalog">
      {enrichedCourses.map((course) => (
        <article class={`public-course-card public-course-card--catalog ${course.pathTheme.border}`}>
          <div class="public-story-meta">
            <span class={`rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.1em] ${course.pathTheme.badge}`}>{course.pathTheme.label}</span>
            <span class="academy-output-mono text-[0.68rem] uppercase tracking-[0.12em] text-slate-500">{course.accessModel === 'registration' ? 'Starter' : 'Cohort'}</span>
          </div>
          <h2>{course.name}</h2>
          <p>{course.shortDescription}</p>
          <div class="public-course-pills">
            <span>{course.lessonCount > 0 ? `${course.lessonCount} lessons` : 'Structured curriculum'}</span>
            <span>{course.deliveryLabel || 'Mentor-guided'}</span>
          </div>
          <div class="public-course-footer">
            <a href={`/courses/${course.slug}`} class="public-inline-link">View details</a>
            <a
              href={course.ctaUrl || course.academyUrl}
              target={course.ctaTarget === '_blank' ? '_blank' : undefined}
              rel={course.ctaTarget === '_blank' ? 'noreferrer' : undefined}
              class="public-inline-action"
            >
              {course.ctaLabel || 'Enroll'}
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
