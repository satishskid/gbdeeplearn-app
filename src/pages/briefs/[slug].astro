---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchPublishedBriefBySlug, fetchPublishedBriefs, formatBriefDate, renderBriefMarkdown } from '../../lib/briefs.js';

export async function getStaticPaths() {
  const posts = await fetchPublishedBriefs(120).catch(() => []);
  return posts
    .filter((post) => String(post?.slug || '').trim())
    .map((post) => ({
      params: { slug: post.slug }
    }));
}

const { slug } = Astro.params;
const post = slug ? await fetchPublishedBriefBySlug(slug).catch(() => null) : null;

if (!post) {
  return Astro.redirect('/briefs');
}

const canonicalUrl = post.canonical_url || `https://med.greybrain.ai/briefs/${post.slug}`;
const publishedLabel = formatBriefDate(post.published_at_ms || post.updated_at_ms || post.created_at_ms);
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.summary,
  datePublished: new Date(post.published_at_ms || post.created_at_ms || Date.now()).toISOString(),
  dateModified: new Date(post.updated_at_ms || post.published_at_ms || post.created_at_ms || Date.now()).toISOString(),
  mainEntityOfPage: canonicalUrl,
  url: canonicalUrl,
  publisher: {
    '@type': 'Organization',
    name: 'GreyBrain Academy',
    url: 'https://med.greybrain.ai'
  },
  keywords: Array.isArray(post.tags) ? post.tags.join(', ') : ''
};
---

<BaseLayout
  title={`${post.title} | GreyBrain Academy`}
  description={post.summary}
  canonical={canonicalUrl}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  </Fragment>

  <section class="mx-auto max-w-5xl px-4 py-12 md:px-6 md:py-16">
    <article class="rounded-[2rem] border border-slate-200 bg-white/95 p-6 shadow-sm md:p-10">
      <div class="mb-6 flex flex-wrap items-center gap-3 text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">
        <span>{post.path || 'brief'}</span>
        {publishedLabel ? <span>{publishedLabel}</span> : null}
      </div>

      <h1 class="max-w-4xl text-3xl font-extrabold leading-tight text-slate-950 md:text-5xl">{post.title}</h1>
      <p class="mt-4 max-w-3xl text-base leading-8 text-slate-600 md:text-lg">{post.summary}</p>

      {Array.isArray(post.tags) && post.tags.length > 0 ? (
        <div class="mt-5 flex flex-wrap gap-2">
          {post.tags.map((tag) => (
            <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs font-semibold text-slate-600">{tag}</span>
          ))}
        </div>
      ) : null}

      <div class="brief-prose mt-10 max-w-none text-slate-800" set:html={renderBriefMarkdown(post.content_markdown || '')} />

      {Array.isArray(post.source_urls) && post.source_urls.length > 0 ? (
        <section class="mt-10 border-t border-slate-200 pt-6">
          <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-slate-500">Sources</h2>
          <div class="mt-3 flex flex-col gap-2">
            {post.source_urls.map((url) => (
              <a
                class="text-sm text-sky-700 underline decoration-slate-300 underline-offset-4"
                href={url}
                rel="noreferrer"
                target="_blank"
              >
                {url}
              </a>
            ))}
          </div>
        </section>
      ) : null}
    </article>
  </section>
</BaseLayout>
