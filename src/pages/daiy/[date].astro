---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchPublishedBriefs } from '../../lib/briefs.js';

export async function getStaticPaths() {
  let allDaiy = [];
  try {
    const API_ORIGIN = import.meta.env.VITE_API_ORIGIN || 'https://deeplearn-worker.satish-9f4.workers.dev';
    const res = await fetch(`${API_ORIGIN}/api/content/posts?content_type=daiy_prompt&limit=100`);
    if (res.ok) {
      const data = await res.json();
      allDaiy = Array.isArray(data.posts) ? data.posts : (Array.isArray(data) ? data : []);
    }
  } catch { /* fallback */ }

  return allDaiy
    .filter((p) => String(p?.date || '').trim())
    .map((p) => ({ 
      params: { date: p.date },
      props: { post: p }
    }));
}

const { date } = Astro.params;
const { post } = Astro.props;

if (!post) {
  return Astro.redirect('/daiy', 308);
}

const DAIY_MODELS = [
  { name: 'CLAUDE', url: 'https://claude.ai' },
  { name: 'GEMINI', url: 'https://gemini.google.com' },
  { name: 'PERPLEXITY', url: 'https://perplexity.ai' },
  { name: 'QWEN', url: 'https://chat.qwen.ai' },
  { name: 'MINIMAX', url: 'https://chat.minimax.io' },
];

const promptText = post.prompt_text || '';
const keyword = post.prompt_keyword || 'Clinical AI';
const preview = post.prompt_output_preview || '';
const pageTitle = post.title || `DAIY Prompt — ${keyword} — ${date}`;
const pageDesc = post.summary || `Today's Do AI Yourself prompt for doctors, focused on ${keyword}. Try it in Claude, Gemini, Perplexity, Qwen, or MiniMax.`;
const canonical = `https://med.greybrain.ai/daiy/${date}`;
const SITE_ORIGIN = 'https://med.greybrain.ai';
const shareText = encodeURIComponent(`I just tried today's #DAIY prompt from @GreyBrainAcademy 🧠\n\nTopic: "${keyword}"\n\nTry it: ${canonical} #AIForDoctors #ClinicalAI`);
const xUrl = `https://twitter.com/intent/tweet?text=${shareText}`;
const liUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonical)}`;

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": pageTitle,
  "description": pageDesc,
  "datePublished": post.date || date,
  "author": { "@type": "Organization", "name": "GreyBrain Academy" },
  "publisher": { "@type": "Organization", "name": "GreyBrain Academy", "url": SITE_ORIGIN },
  "url": canonical,
  "keywords": `DAIY, Do AI Yourself, ${keyword}, AI for doctors, clinical AI, GreyBrain Academy`
});
---

<BaseLayout title={pageTitle} description={pageDesc} canonical={canonical}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={articleSchema} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonical} />
  </Fragment>

  <div class="ce-page-shell">
    <!-- Back nav -->
    <a href="/daiy" class="inline-flex items-center gap-2 text-slate-500 hover:text-teal-700 text-sm font-bold mb-8 transition">
      ← All DAIY Prompts
    </a>

    <!-- Keyword chip + date -->
    <div class="flex flex-wrap items-center gap-3 mb-4">
      <span class="ce-card__keyword text-base px-4 py-1">{keyword}</span>
      <span style="font-family:'IBM Plex Mono',monospace;font-size:0.7rem;color:#64748b">{date}</span>
    </div>

    <h1 class="text-3xl md:text-5xl mb-3">{pageTitle}</h1>
    {post.summary && <p class="text-slate-600 text-lg mb-8 max-w-2xl">{post.summary}</p>}

    <!-- Terminal Prompt Block -->
    <div class="ce-term-prompt">
      <div style="display:flex;align-items:center;gap:0.4rem;margin-bottom:1rem">
        <span style="width:10px;height:10px;border-radius:50%;background:#ff5f57;display:inline-block"></span>
        <span style="width:10px;height:10px;border-radius:50%;background:#febc2e;display:inline-block"></span>
        <span style="width:10px;height:10px;border-radius:50%;background:#28c840;display:inline-block"></span>
        <span style="font-family:'IBM Plex Mono',monospace;font-size:0.65rem;color:rgba(255,255,255,0.25);margin-left:0.5rem">daily-prompt.txt — GreyBrain Academy DAIY</span>
      </div>
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;margin-bottom:1rem">
        <span style="font-family:'IBM Plex Mono',monospace;font-size:0.65rem;color:rgba(34,211,238,0.5);font-weight:700">›_ TODAY'S PROMPT</span>
        <button
          id="daiy-copy-btn"
          class="daiy-copy-btn"
          data-prompt={promptText}
          aria-label="Copy prompt to clipboard"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
          <span id="copy-label">[COPY_PROMPT]</span>
        </button>
      </div>
      <pre id="prompt-text" class="ce-term-prompt" style="background:transparent;border:none;padding:0;margin:0">{promptText}</pre>
    </div>

    <!-- Output preview -->
    {preview && (
      <div class="daiy-preview-card" style="margin-bottom:2rem">
        <p style="font-size:0.72rem;font-weight:800;color:#818cf8;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.5rem">WHAT YOU'LL GET →</p>
        <p style="color:#cbd5e1;font-size:0.9rem;line-height:1.7">{preview}</p>
      </div>
    )}

    <!-- Try it in -->
    <div style="margin-bottom:2rem">
      <p style="font-family:'IBM Plex Mono',monospace;font-size:0.65rem;color:#64748b;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:0.75rem">TRY IN →</p>
      <div class="ce-model-link-row">
        {DAIY_MODELS.map(m => (
          <a href={m.url} target="_blank" rel="noreferrer" class="ce-model-link">
            [{m.name} ↗]
          </a>
        ))}
      </div>
    </div>

    <!-- Share + like -->
    <div style="display:flex;align-items:center;flex-wrap:wrap;gap:0.75rem;border-top:1px solid #e2e8f0;padding-top:1.5rem;margin-top:1rem">
      <button
        id="daiy-like-btn"
        data-post-id={post.id || ''}
        style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.5rem 1.25rem;font-size:0.8rem;font-weight:700;color:#64748b;border:1px solid #e2e8f0;border-radius:2rem;background:transparent;cursor:pointer;"
        aria-label="Like this prompt"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
        <span id="like-label">{(post.community_likes || 0) > 0 ? `${post.community_likes} liked this` : 'Like this prompt'}</span>
      </button>
      <a href={xUrl} target="_blank" rel="noreferrer" class="daiy-share-btn daiy-share-x">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.745l7.73-8.835L1.254 2.25H8.08l4.261 5.636 5.903-5.636Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        Post on X
      </a>
      <a href={liUrl} target="_blank" rel="noreferrer" class="daiy-share-btn daiy-share-li">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        Share on LinkedIn
      </a>
    </div>
  </div>

  <script>
    const copyBtn = document.getElementById('daiy-copy-btn');
    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        const text = copyBtn.getAttribute('data-prompt') || '';
        try {
          await navigator.clipboard.writeText(text);
          const lbl = document.getElementById('copy-label');
          if (lbl) {
            lbl.textContent = '[COPIED ✓]';
            setTimeout(() => { lbl.textContent = '[COPY_PROMPT]'; }, 2200);
          }
        } catch { /* ignore */ }
      });
    }
    const likeBtn = document.getElementById('daiy-like-btn');
    if (likeBtn) {
      const postId = likeBtn.getAttribute('data-post-id') || '';
      const key = `daiy_liked_${postId}`;
      if (localStorage.getItem(key)) {
        likeBtn.style.color = '#f43f5e';
        likeBtn.style.borderColor = 'rgba(244,63,94,0.3)';
      }
      likeBtn.addEventListener('click', async () => {
        if (!postId || localStorage.getItem(key)) return;
        try {
          const origin = document.documentElement.getAttribute('data-api-origin') || 'https://deeplearn-worker.satish-9f4.workers.dev';
          const res = await fetch(`${origin}/api/content/posts/${encodeURIComponent(postId)}/like`, { method: 'POST' });
          const data = await res.json();
          localStorage.setItem(key, '1');
          const lbl = document.getElementById('like-label');
          const n = data?.community_likes ?? 0;
          if (lbl) lbl.textContent = n > 0 ? `${n} liked this` : 'Liked!';
          likeBtn.style.color = '#f43f5e';
        } catch { /* ignore */ }
      });
    }
  </script>
</BaseLayout>
